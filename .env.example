# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to git.
# ─────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────
# Local SQLite (default — leave blank for local dev with SQLite)
# DATABASE_URL=sqlite:///./maintenance_mvp.db

# Supabase Postgres (set this in production):
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
DATABASE_URL=

# Optional pool tuning (PostgreSQL only)
# DB_POOL_SIZE=10
# DB_MAX_OVERFLOW=20

# ── Auth ──────────────────────────────────────────────────────
# Generate a strong random secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-before-deploying
JWT_EXPIRE_MINUTES=480

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (no trailing slash)
# For Render full-stack (backend serves frontend): set to your Render URL
# For Vercel + Render split: add both origins
# ALLOWED_ORIGINS=https://yourapp.vercel.app,https://yourapp.onrender.com
ALLOWED_ORIGINS=http://localhost:8000,http://localhost:3000

# ── Environment ───────────────────────────────────────────────
# "development" | "production"
ENV=development

# ── Twilio (WhatsApp) ─────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Skip Twilio signature validation (set to false in production)
TWILIO_VERIFY_SIGNATURE=false

# ── Anthropic (LLM triage) ────────────────────────────────────
ANTHROPIC_API_KEY=
LLM_MODEL=claude-haiku-4-5-20251001
LLM_TIMEOUT_SECONDS=15

# ── Future: Fernet encryption key for per-company Twilio tokens ──
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# CREDENTIAL_ENCRYPTION_KEY=
